{
	"author": "Toufiqur Rahaman Chowdhury",
	"description": "RxJS based utilities, components and hooks for React applications.",
	"dependencies": {
		"@superutils/core": "*",
		"@superutils/rx": "*",
		"@types/react": "^18.0.0",
		"react": ">=16.8.0",
		"react-dom": ">=16.8.0",
		"rxjs": "^7.0.0"
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.2"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"keywords": [
		"rxjs",
		"utils",
		"typescript",
		"react",
		"hooks"
	],
	"license": "MIT",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"name": "@superutils/rx-react",
	"peerDependencies": {
		"@superutils/core": "*",
		"@superutils/rx": "*"
	},
	"private": true,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"_build": "tsc -p tsconfig.json",
		"_watch": "tsc -p tsconfig.json --watch",
		"build": "tsup src/index.ts --format esm --dts --tsconfig ./tsconfig.dts.json --clean --config ../../tsup.config.js",
		"dev": "npm run build -- --watch",
		"test": "cd ../../ && npm run test rx-react"
	},
	"sideEffects": false,
	"type": "module",
	"types": "./dist/index.d.ts",
	"version": "0.1.0"
}
